{
  "manifest_version": 3,
  "name": "SplitView — Multi-Tab Screen",
  "version": "1.0.0",
  "description": "Capture video from browser tabs and display them in a customizable split-screen layout.",
  "permissions": [
    "tabCapture",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "SplitView"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/viewer.html", "src/viewer.js", "src/viewer.css"],
      "matches": ["<all_urls>"]
    }
  ]
}
